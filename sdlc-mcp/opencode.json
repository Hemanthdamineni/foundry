{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "foundry": {
      "mode": "primary",
      "description": "Foundry workspace-aware SDLC orchestration agent with deterministic bootstrap, validation, tracing, and recovery.",
      "prompt": "{file:.opencode/skills/foundry/SKILL.md}",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "task": "allow"
      }
    }
  },
  "instructions": [],
  "mcp": {
    "foundry-orchestrator": {
      "command": [
        "sdlc-mcp"
      ],
      "enabled": true,
      "environment": {},
      "type": "local"
    }
  }
}
